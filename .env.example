# ============================================================
# CareerFarm — single env file for BOTH apps (backend + frontend)
# Copy to .env and fill in. Backend reads this file directly;
# frontend loads it via dotenv-cli in its npm scripts.
# ============================================================

# --- Supabase project (shared; same project for both apps) ---
# Backend uses SUPABASE_URL; frontend needs the NEXT_PUBLIC_ copy
# (same value) because browser vars must be prefixed.
SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co

# --- Backend only (secrets — never exposed to the browser) ---
# Postgres connection string (Project Settings -> Database)
DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# JWT secret (Project Settings -> API -> JWT Secret) — verifies auth tokens
SUPABASE_JWT_SECRET=your-jwt-secret
# Anthropic API key (unused until CV Studio)
ANTHROPIC_API_KEY=sk-ant-...
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Frontend only (NEXT_PUBLIC_ = exposed to the browser) ---
# FastAPI backend base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
# Supabase anon/public key (Project Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
